# =============================================================
# EditorConfig — WA Health HSS Azure Landing Zone
# Ensures consistent coding style across all editors and IDEs.
# See: https://editorconfig.org
# =============================================================
root = true

# All files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Bicep files
[*.bicep]
indent_style = space
indent_size = 2
max_line_length = 120

# Bicepparam files
[*.bicepparam]
indent_style = space
indent_size = 2

# YAML (GitHub Actions, Azure Pipelines)
[*.{yml,yaml}]
indent_style = space
indent_size = 2
max_line_length = 120

# JSON (bicepconfig, package.json, etc.)
[*.json]
indent_style = space
indent_size = 2

# PowerShell scripts
[*.ps1]
indent_style = space
indent_size = 4
end_of_line = crlf

# Markdown documentation
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# TOML (gitleaks config)
[*.toml]
indent_style = space
indent_size = 2

# Shell scripts
[*.sh]
indent_style = space
indent_size = 2
end_of_line = lf
